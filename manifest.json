{
  "manifest_version": 2,
  "name": "YT Bilingual Translator",
  "version": "0.29.0",
  "description": "YouTube bilingual subtitles with a clean SVG in-player toggle, automatic native-caption hiding, target-language translation, and interactive vocabulary cards.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "*://*.youtube.com/*",
    "https://translate.googleapis.com/*",
    "https://clients5.google.com/*",
    "https://translation.googleapis.com/*",
    "https://api.dictionaryapi.dev/*",
    "https://libretranslate.com/*",
    "https://*.libretranslate.com/*",
    "https://api.mymemory.translated.net/*",
    "https://lingva.ml/*",
    "https://*.lingva.ml/*",
    "https://*.run.app/*",
    "https://*.cloudfunctions.net/*",
    "https://edge.microsoft.com/*",
    "https://api-edge.cognitive.microsofttranslator.com/*",
    "https://*.wikipedia.org/*",
    "https://commons.wikimedia.org/*",
    "https://upload.wikimedia.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "i18n.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "YT Bilingual Translator",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "popup/popup.html",
    "browser_style": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-bilingual-subtitle-translator@github-ErttyOuO",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "websiteContent"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "web_accessible_resources": [
    "page-bridge.js"
  ],
  "homepage_url": "https://github.com/ErttyOuO/YT-bilingual-translator"
}
