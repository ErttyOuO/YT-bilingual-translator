{
  "manifest_version": 3,
  "name": "YT Bilingual Translator",
  "version": "0.26.0",
  "description": "YouTube bilingual subtitles with an in-player toggle, automatic native-caption hiding, target-language translation, and interactive vocabulary cards.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://translate.googleapis.com/*",
    "https://clients5.google.com/*",
    "https://translation.googleapis.com/*",
    "https://api.dictionaryapi.dev/*",
    "https://libretranslate.com/*",
    "https://*.libretranslate.com/*",
    "https://api.mymemory.translated.net/*",
    "https://lingva.ml/*",
    "https://*.lingva.ml/*",
    "https://*.run.app/*",
    "https://*.cloudfunctions.net/*",
    "https://edge.microsoft.com/*",
    "https://api-edge.cognitive.microsofttranslator.com/*",
    "https://*.wikipedia.org/*",
    "https://commons.wikimedia.org/*",
    "https://*.wikimedia.org/*",
    "https://api.openverse.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "i18n.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "YT Bilingual Translator",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_popup": "popup/popup.html"
  },
  "options_page": "popup/popup.html",
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ]
    }
  ]
}
